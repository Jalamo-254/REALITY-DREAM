{
  "name": "reality-dream-static",
  "version": "1.0.0",
  "description": "Static site assets and helper scripts for Reality Dream Institute",
  "scripts": {
    "optimize-images": "node scripts/optimize-images.js",
    "build:css": "npx tailwindcss -i Assets/css/tailwind-input.css -o Assets/css/tailwind.css --minify --content \"./**/*.html\" \"./**/*.js\"",
    "normalize-images": "node scripts/normalize-image-names.js"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "imagemin-svgo": "^12.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19"
  }
}
